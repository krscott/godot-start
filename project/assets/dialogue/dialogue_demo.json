{
	"events": {
		"start": {
			"next": [
				"alice_is_dead",
				"intro"
			]
		},
		"intro": {
			"speaker": "Alice",
			"text": "Hi! My name is Alice!",
			"next": "start_game"
		},
		"start_game": {
			"speaker": "Alice",
			"text": [
				"Let's play rock paper scissors!",
				"Ready? Rock, paper, scissors..."
			],
			"choices": [
				{
					"text": "Rock",
					"callback": [
						"choose",
						"rock"
					],
					"next": "play_game"
				},
				{
					"text": "Paper",
					"callback": [
						"choose",
						"paper"
					],
					"next": "play_game"
				},
				{
					"text": "Scissors",
					"callback": [
						"choose",
						"scissors"
					],
					"next": "play_game"
				},
				{
					"text": "Shoot",
					"callback": "shot_alice",
					"next": "shoot_alice"
				}
			]
		},
		"play_game": {
			"speaker": "Alice",
			"text": [
				"*Alice throws ${alice_choice}*"
			],
			"next": [
				"win_game",
				"lose_game"
			]
		},
		"win_game": {
			"cond": "is_win",
			"speaker": "Alice",
			"text": [
				"Oh, you won...",
				"Let's go again"
			],
			"choices": [
				{
					"text": "Ok",
					"next": "start_game"
				},
				{
					"text": "No, thanks",
					"next": "end_game"
				}
			]
		},
		"lose_game": {
			"speaker": "Alice",
			"text": [
				"Ha, {alice_choice} beats {player_choice}!",
				"Too bad!",
				"Go again?"
			],
			"choices": [
				{
					"text": "Ok",
					"next": "start_game"
				},
				{
					"text": "No, thanks",
					"next": "end_game"
				}
			]
		},
		"shoot_alice": {
			"text": [
				"Ow!",
				"*Alice dies*"
			]
		},
		"alice_is_dead": {
			"cond": "alice_is_dead",
			"text": [
				"Alice is dead and doesn't want to play any more"
			]
		}
	}
}
