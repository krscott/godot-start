#!/usr/bin/env sh
set -eu

echo ""
echo "Validating .import files..."

find_files() {
    find . -not -path '*/.git/*' -name "$1" -type f
}

check_png_import() {
    # Search for all .png.import files and check for compress/mode=0
    files=$(find_files "*.png.import")

    if [ -z "$files" ]; then
        return 0
    fi

    found_any=

    for file in $files; do
        if ! grep -q "compress/mode=0" "$file"; then
            echo "$file does not contain 'compress/mode=0'"
            found_any=1
        fi
    done

    if [ -n "$found_any" ]; then
        echo "FAILED: Re-import these files with Compress Mode 'Lossless'"
        return 1
    fi
}

# NOTE: Skip this if not doing a pixel-art game
check_png_import

echo "PASS"
