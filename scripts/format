#!/usr/bin/env bash
set -euo pipefail
shopt -s failglob
shopt -s globstar

usage() {
    # NOTE: Don't forget to update OPTIONS/LONGOPTS below!
    cat <<EOF
Usage: $(basename "$0") [options] [command]

Commands:
    format              Run formatter (default)
    lint                Run linter

Options:
    -c, --check         Check formatting without editing
    -f, --file FILE     Only run on a single file
    -h, --help          Display this help message
    -v, --verbose       Enable debug messages
EOF
}

# NOTE: Use ':' suffix to specify opt has an arg
OPTIONS="cf:hv"
LONGOPTS="check,file:,help,verbose"

# NOTE: getopt comes from 'util-linux' package
# Check if getopt is available, fallback to simple parsing if not
if command -v getopt &>/dev/null; then
    PARSED=$(getopt -o "$OPTIONS" -l "$LONGOPTS" -n "$0" -- "$@") || {
        usage >&2
        exit 2
    }
    eval set -- "$PARSED"
fi

fatal_usage() {
    echo "$*" >&2
    echo
    usage >&2
    exit 2
}

fatal() {
    echo "$*" >&2
    exit 1
}

log() {
    local c="$1"
    shift
    [[ $c ]] && echo -ne "\033[${c}m" >&2
    echo -e "$@" >&2
    [[ $c ]] && echo -ne '\033[0m' >&2
    return 0
}
debug() {
    [[ -n ${verbose:-} ]] && log "" "$@"
    return 0
}
warn() { log "0;33" "$@"; }
error() { log "0;31" "$@"; }

require_cmd() {
    command -v "$1" >/dev/null || fatal "Missing required command: $1"
}

run() {
    if [[ -n ${verbose:-} ]]; then
        printf '+ ' >&2
        printf '%q ' "$@" >&2
        printf '\n' >&2
    fi

    "$@"
}

args_nix=
args_gd=
file=
verbose=
while [[ $# -gt 0 ]]; do
    case "$1" in
    -c | --check)
        args_nix=--check
        args_gd=--check
        ;;
    -h | --help)
        usage
        exit 0
        ;;
    -f | --file)
        [[ ${2:-} ]] || fatal_usage "--file requires an argument"
        file="$2"
        shift
        ;;
    -v | --verbose) verbose=1 ;;
    --)
        shift
        break
        ;;
    -*)
        fatal_usage "Unknown option: $1"
        ;;
    *)
        # Non-option argument, stop parsing
        break
        ;;
    esac
    shift
done

(($# > 1)) && fatal_usage "Too many arguments"

iscmd() {
    command -v "$1" >/dev/null
}

anyfiles() {
    find . -type f -name "*.$1" -print -quit | grep -q .
}

case "${1:-format}" in
lint)
    if [[ -n $file ]]; then
        [[ -f $file ]] || fatal "File not found: $file"
        [[ $file == *.gd ]] || fatal "--file for lint must be a .gd file"
        require_cmd gdscript-formatter

        run gdscript-formatter lint \
            --disable constant-name,private-access,class-name \
            "$file"
    else
        require_cmd gdscript-formatter
        run gdscript-formatter lint \
            --disable constant-name,private-access,class-name \
            ./**/*.gd
    fi
    ;;
format)
    if [[ -n $file ]]; then
        [[ -f $file ]] || fatal "File not found: $file"

        if [[ $file == *.gd ]]; then
            require_cmd gdscript-formatter
            run gdscript-formatter $args_gd "$file"
        elif [[ $file == *.nix ]]; then
            require_cmd nix
            run nix fmt "$file" -- $args_nix
        else
            fatal "--file must be a .gd or .nix file"
        fi
    else
        if anyfiles "gd"; then
            require_cmd gdscript-formatter
            run gdscript-formatter $args_gd ./**/*.gd
        fi

        if iscmd nix && anyfiles "nix"; then
            run nix fmt ./**/*.nix -- $args_nix
        fi
    fi
    ;;
*)
    error "Unknown command '$1'"
    usage
    exit 3
    ;;
esac
