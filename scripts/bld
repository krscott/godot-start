#!/usr/bin/env bash
set -euo pipefail
shopt -s failglob

SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
cd "$SCRIPT_DIR/../project"

usage() {
    # NOTE: Don't forget to update OPTIONS/LONGOPTS below!
    cat <<EOF
Usage: $(basename "$0") [options] [preset]

Arguments:
    preset              Build preset (default: "Linux")

Options:
    -d, --debug         Build in debug mode
    -w, --wrapped       Build with compatibility wrapper
    -z, --zip           Create an archive zip
    -h, --help          Display this help message
    -v, --verbose       Enable debug messages
EOF
}

# NOTE: Use ':' suffix to specify opt has an arg
OPTIONS="dwzhv"
LONGOPTS="debug,wrapped,zip,help,verbose"

# NOTE: getopt comes from 'util-linux' package
# Check if getopt is available, fallback to simple parsing if not
if command -v getopt &>/dev/null; then
    PARSED=$(getopt -o "$OPTIONS" -l "$LONGOPTS" -n "$0" -- "$@") || {
        usage >&2
        exit 2
    }
    eval set -- "$PARSED"
fi

fatal_usage() {
    echo "$*" >&2
    echo
    usage >&2
    exit 2
}

fatal() {
    echo "$*" >&2
    exit 1
}

log() {
    local c="$1"
    shift
    [[ $c ]] && echo -ne "\033[${c}m" >&2
    echo -e "$@" >&2
    [[ $c ]] && echo -ne '\033[0m' >&2
    return 0
}
debug() {
    [[ -n ${verbose:-} ]] && log "" "$@"
    return 0
}
warn() { log "0;33" "$@"; }
error() { log "0;31" "$@"; }

print_first_match_block() {
    local pattern="$1"
    printf '%s\n' "$output" | grep -m1 -A1 --no-group-separator "$pattern" >&2 || true
}

require_cmd() {
    command -v "$1" >/dev/null || fatal "Missing required command: $1"
}

run() {
    if [[ -n ${verbose:-} ]]; then
        printf '+ ' >&2
        printf '%q ' "$@" >&2
        printf '\n' >&2
    fi

    "$@"
}

zip=
export_type="release"
wrapped=
verbose=
while [[ $# -gt 0 ]]; do
    case "$1" in
    -d | --debug)
        export_type="debug"
        ;;
    -w | --wrapped)
        wrapped=1
        ;;
    -z | --zip)
        zip=1
        ;;
    -h | --help)
        usage
        exit 0
        ;;
    -v | --verbose) verbose=1 ;;
    --)
        shift
        break
        ;;
    -*)
        fatal_usage "Unknown option: $1"
        ;;
    *)
        # Non-option argument, stop parsing
        break
        ;;
    esac
    shift
done

preset="${1:-Linux}"
(($# > 1)) && fatal_usage "Too many arguments"

PNAME=godot-start
BUILD_DIR=../build

mkWrapperScript() {
    cat <<EOS
#!/usr/bin/env sh
set -eu

SCRIPT_DIR="\$(dirname "\$(readlink -f -- "\$0")")"
steam-run "\$SCRIPT_DIR/$PNAME-bin" "\$@"
EOS
}

mkWebRunnerScript() {
    cat <<EOS
#!/usr/bin/env sh
set -eu

cd "\$(dirname "\$(readlink -f -- "\$0")")"

(
    sleep 0.1
    xdg-open http://127.0.0.1:8000
) &

python -m http.server
EOS
}

run_godot() {
    output=$(run godot --headless "$@" 2>&1 | tee /dev/stderr)
    if printf '%s\n' "$output" | grep -q '^SCRIPT ERROR:'; then
        error "Failed: Script error"
        print_first_match_block '^SCRIPT ERROR:'
        exit 1
    fi
    # Catches engine-internal false positives
    # if printf '%s\n' "$output" | grep -q '^ERROR:'; then
    #     error "Failed: Error"
    #     print_first_match_block '^ERROR:'
    #     exit 1
    # fi
}

require_cmd godot

mkdir -p "$BUILD_DIR"

[[ -d "$BUILD_DIR/$PNAME-$preset" ]] && rm -rf "$BUILD_DIR/$PNAME-$preset"

if command -v install-export-templates >/dev/null; then
    run install-export-templates
fi

if [[ $preset = "Web" ]]; then
    mkdir -p "$BUILD_DIR/$PNAME-$preset"
    run_godot --export-"$export_type" "$preset" "$BUILD_DIR/$PNAME-$preset/index.html"

    if [[ $wrapped ]]; then
        mkWebRunnerScript >"$BUILD_DIR/$PNAME-$preset/$PNAME"
        chmod +x "$BUILD_DIR/$PNAME-$preset/$PNAME"
    fi

    if [[ $zip ]]; then
        require_cmd zip
        (cd "$BUILD_DIR/$PNAME-$preset" && run zip -r ../"$PNAME-$preset.zip" ./*)
    fi
elif [[ $zip ]]; then
    run_godot --export-"$export_type" "$preset" "$BUILD_DIR/$PNAME-$preset.zip"
elif [[ $wrapped ]]; then
    mkdir -p "$BUILD_DIR/$PNAME-$preset"
    run_godot --export-"$export_type" "$preset" "$BUILD_DIR/$PNAME-$preset/$PNAME-bin"
    mkWrapperScript >"$BUILD_DIR/$PNAME-$preset/$PNAME"
    chmod +x "$BUILD_DIR/$PNAME-$preset/$PNAME"
elif [[ $preset = "Windows" ]]; then
    mkdir -p "$BUILD_DIR/$PNAME-$preset"
    run_godot --export-"$export_type" "$preset" "$BUILD_DIR/$PNAME-$preset/$PNAME.exe"
else
    mkdir -p "$BUILD_DIR/$PNAME-$preset"
    run_godot --export-"$export_type" "$preset" "$BUILD_DIR/$PNAME-$preset/$PNAME"
fi
